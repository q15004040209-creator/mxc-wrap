  "network": {
    "allowOutbound": false,
    "proxy": null,
    "allowedHosts": [],
    "blockedHosts": []
  },
  "ui": {
    "clipboard": "deny",
    "display": "deny",
    "gui": "deny"
  },
  "timeoutMs": 30000,
  "experimental": false
}
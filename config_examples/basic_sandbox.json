{
  "version": "0.6.0-alpha",
  "process": {
    "commandLine": "python -c \"print('Hello from MXC sandbox!')\"",
    "cwd": "/tmp"
  },
  "filesystem": {
    "readonlyPaths": [
      "/usr/bin",
      "/usr/lib",
      "/bin",
      "/lib",
      "/opt"
    ],
    "readwritePaths": [
      "/tmp",
      "/var/tmp"
    ],
